# Supabase public credentials (safe for the browser — protected by RLS).
# Copy to `.env` for local dev. In production these are injected by GitHub Actions.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Telegram support bot (set as Supabase Edge Function secrets, NOT in the frontend) ---
# supabase secrets set KEY=value
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...          # від @BotFather
TELEGRAM_WEBHOOK_SECRET=long-random-string     # довільний секрет для захисту webhook
ANTHROPIC_API_KEY=sk-ant-...                   # ключ Claude (ШІ-відповіді)
ANTHROPIC_MODEL=claude-haiku-4-5               # актуальна модель Haiku (3.5 виведено з експлуатації)
ANTHROPIC_MAX_TOKENS=350                        # ліміт довжини відповіді ШІ (менше = дешевше)
ADMIN_CHAT_ID=-1001234567890                   # ID чату/групи операторів для ескалації
# LiqPay (опційно — автоматична оплата карткою). Без них працює лише Privat24-посилання.
LIQPAY_PUBLIC_KEY=i00000000000
LIQPAY_PRIVATE_KEY=...
LIQPAY_CALLBACK_URL=https://YOUR-ref.functions.supabase.co/liqpay-callback
